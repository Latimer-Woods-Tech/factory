{
  "name": "video-cron",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "hyperdrive": [
    {
      "binding": "DB",
      "id": "REPLACE_WITH_HYPERDRIVE_ID"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "vars": {},
  "env": {
    "production": {
      "name": "video-cron",
      "triggers": {
        "crons": ["0 * * * *"]
      }
    }
  }
}
