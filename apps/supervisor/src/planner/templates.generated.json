  {
    "id": "wrangler-config-drift-fix",
    "tier": "yellow",
    "description": "",
    "trigger_keywords": [
      "bug",
      "wrangler",
      "config",
      "drift",
      "fix"
    ],
    "triggers": {
      "labels_any_of": [
        "bug"
      ],
      "title_pattern": "(wrangler|binding|Hyperdrive)",
      "body_patterns": [
        "(wrangler\\.jsonc|binding|hyperdrive|kv|r2|d1|durable_object)"
      ]
    },
    "slot_names": [
      "app_name",
      "binding_kind",
      "binding_id",
      "worker_name"
    ],
    "step_intents": [
      "Read the worker's current wrangler.jsonc to inspect declared bindings.",
      "Verify whether the referenced binding exists in the Cloudflare account and resolve the correct ID if drifted.",
      "Cross-check the worker's deploy status to confirm the drift is live and not mid-deploy.",
      "Open a PR with the corrected binding ID so a human can review and merge."
    ],
    "pr_files": [],
    "steps": [
      {
        "tool": "github.readFile",
        "slots": {
          "repo": "$slots.app_name",
          "path": "wrangler.jsonc"
        },
        "side_effects": "none"
      },
      {
        "tool": "cloudflare.listWorkers",
        "slots": {
          "filter_binding_kind": "$slots.binding_kind",
          "filter_binding_id": "$slots.binding_id"
        },
        "side_effects": "none"
      },
      {
        "tool": "factory_admin.worker.status",
        "slots": {
          "worker": "$slots.worker_name"
        },
        "side_effects": "none"
      },
      {
        "tool": "github.openPR",
        "slots": {
          "repo": "$slots.app_name",
          "branch": "supervisor/wrangler-drift-$slots.worker_name",
          "title": "fix(wrangler): correct $slots.binding_kind binding for $slots.worker_name",
          "body": "Automated fix: wrangler.jsonc referenced a stale $slots.binding_kind binding. Updated to the resolved ID from cloudflare.listWorkers (see $s2). Current file state captured in $s1.",
          "files": [
            {
              "path": "wrangler.jsonc",
              "from_step": "s1",
              "patch_kind": "update_binding",
              "binding_kind": "$slots.binding_kind",
              "new_binding_id": "$s2.resolved_id"
            }
          ]
        },
        "side_effects": "none"
      }
    ]
  }
]
