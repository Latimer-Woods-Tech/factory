{
  "name": "synthetic-monitor",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "ENVIRONMENT": "development",
    "TARGETS_JSON": "[]"
  },
  "env": {
    "production": {
      "name": "synthetic-monitor",
      "workers_dev": true,
      "triggers": {
        "crons": ["*/5 * * * *"]
      },
      "vars": {
        "ENVIRONMENT": "production",
        "TARGETS_JSON": "[]"
      }
    }
  }
}
