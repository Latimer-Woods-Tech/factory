{
  "$schema": "https://developers.cloudflare.com/workers/wrangler/config-schema.json",
  "name": "synthetic-monitor",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "ENVIRONMENT": "development",
    "TARGETS_JSON": "[]"
  },
  "env": {
    "production": {
      "name": "synthetic-monitor",
      "workers_dev": true,
      "triggers": {
        "crons": ["*/5 * * * *"]
      },
      "vars": {
        "ENVIRONMENT": "production",
        "TARGETS_JSON": "[{\"id\":\"selfprime.home\",\"url\":\"https://selfprime.net/\",\"contains\":\"Prime Self\"},{\"id\":\"selfprime.pricing\",\"url\":\"https://selfprime.net/pricing.html\",\"contains\":\"Plans\"},{\"id\":\"selfprime.practitioners\",\"url\":\"https://selfprime.net/practitioners.html\",\"contains\":\"Practitioner\"},{\"id\":\"selfprime.api.health\",\"url\":\"https://prime-self.adrper79.workers.dev/health\",\"contains\":\"ok\"},{\"id\":\"prime-self.api\",\"url\":\"https://prime-self.adrper79.workers.dev/health\",\"expectedStatus\":200},{\"id\":\"admin-studio.staging.health\",\"url\":\"https://admin-studio-staging.adrper79.workers.dev/health\",\"expectedStatus\":200,\"contains\":\"ok\"},{\"id\":\"schedule-worker.health\",\"url\":\"https://schedule-worker.adrper79.workers.dev/health\",\"expectedStatus\":200},{\"id\":\"video-cron.health\",\"url\":\"https://video-cron.adrper79.workers.dev/health\",\"expectedStatus\":200},{\"id\":\"schedule-worker.manifest\",\"url\":\"https://schedule-worker.adrper79.workers.dev/manifest\",\"expectedStatus\":200,\"contains\":\"manifestVersion\"},{\"id\":\"video-cron.manifest\",\"url\":\"https://video-cron.adrper79.workers.dev/manifest\",\"expectedStatus\":200,\"contains\":\"manifestVersion\"},{\"id\":\"admin-studio.manifest\",\"url\":\"https://admin-studio-staging.adrper79.workers.dev/manifest\",\"expectedStatus\":200,\"contains\":\"manifestVersion\"},{\"id\":\"slo.journey.render-ingest\",\"url\":\"https://schedule-worker.adrper79.workers.dev/health\",\"expectedStatus\":200,\"contains\":\"ok\"},{\"id\":\"slo.journey.video-dispatch\",\"url\":\"https://video-cron.adrper79.workers.dev/health\",\"expectedStatus\":200,\"contains\":\"ok\"},{\"id\":\"slo.journey.auth-api\",\"url\":\"https://prime-self.adrper79.workers.dev/health\",\"expectedStatus\":200,\"contains\":\"ok\"},{\"id\":\"slo.journey.operator-plane\",\"url\":\"https://admin-studio-staging.adrper79.workers.dev/health\",\"expectedStatus\":200,\"contains\":\"ok\"},{\"id\":\"slo.journey.webhook\",\"url\":\"https://schedule-worker.adrper79.workers.dev/stripe/health\",\"expectedStatus\":200,\"contains\":\"ok\"}]"
      }
    }
  }
}
