# local-only secrets — never commit
JWT_SECRET=replace-me-with-32-bytes-of-random-base64
STUDIO_ADMIN_EMAIL=operator@example.com
# Generate locally: printf "your-password" | sha256sum
STUDIO_ADMIN_PASSWORD_SHA256=replace-me-with-lowercase-sha256-hex
GITHUB_TOKEN=ghp_replace_me
ANTHROPIC_API_KEY=sk-ant-replace-me
# optional fallbacks
XAI_API_KEY=
GROQ_API_KEY=
SENTRY_DSN=

# Phase B observability proxies — all optional. When unset, the
# corresponding /apps/versions, /observability/sentry, /observability/posthog
# endpoints return { configured: false } instead of failing.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com
