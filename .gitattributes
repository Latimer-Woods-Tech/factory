# Normalize line endings to LF in the repo; let the OS check out its native endings
* text=auto eol=lf

# Explicitly force LF for files that must not have CRLF on any platform
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.json   text eol=lf
*.jsonc  text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.env    text eol=lf
*.toml   text eol=lf
*.lock   text eol=lf

# Binary files — never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.mp4    binary
*.mp3    binary
*.zip    binary
*.tar    binary
*.gz     binary
