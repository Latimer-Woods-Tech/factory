{
  "name": "@adrper79-dot/ui",
  "version": "0.2.0",
  "private": false,
  "description": "Accessible, reusable UI primitives for all Factory apps (Button, Input, Modal, etc.)",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./Button": {
      "import": "./dist/Button.mjs",
      "types": "./dist/Button.d.mts"
    },
    "./Input": {
      "import": "./dist/Input.mjs",
      "types": "./dist/Input.d.mts"
    },
    "./Label": {
      "import": "./dist/Label.mjs",
      "types": "./dist/Label.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --coverage",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prepublish": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@adrper79-dot/design-tokens": "0.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@adrper79-dot/design-tokens": "0.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.1.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
