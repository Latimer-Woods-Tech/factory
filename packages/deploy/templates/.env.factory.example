# Factory App — Required Environment Variables
# Copy this file, rename to .env (never commit it), and fill in each value.
# For Cloudflare Workers, use `wrangler secret put` or scripts/setup-secrets.sh
# to set production values — never put secrets in wrangler.jsonc vars.

# ── Database ───────────────────────────────────────────────────────────────
# Neon Postgres connection string (use Hyperdrive binding in production)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ───────────────────────────────────────────────────────────────────
# 32-byte random secret for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET=

# ── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@oXXXXX.ingest.sentry.io/XXXXXXX
POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AI / LLM ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROK_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Telephony ──────────────────────────────────────────────────────────────
TELNYX_API_KEY=KEY_XXXXXXXX_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELNYX_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DEEPGRAM_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ELEVENLABS_API_KEY=sk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Sentry CLI (for release tagging in deploy.sh) ─────────────────────────
# SENTRY_AUTH_TOKEN=sntrys_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# SENTRY_ORG=my-sentry-org
